# Copy to /root/smartbag_alert/config/smartbag.env on the board.
SMARTBAG_HOME=/root/smartbag_alert
SMARTBAG_OM_MODEL=/root/smartbag_alert/intelligent_bag/models/yolo11s.om
SMARTBAG_AUDIO_ROOT=/root/smartbag_alert/audio
SMARTBAG_BLE_NAME=SS928-SmartBag
SMARTBAG_EVENT_TIMEOUT=1.0
# TCA9548A: BMI270=channel 0, left TM6605=channel 1, right TM6605=channel 2.
SMARTBAG_I2C_DEV=/dev/i2c-0
SMARTBAG_TM6605_USE_MUX=1
SMARTBAG_TM6605_MUX_ADDR=0x70
SMARTBAG_LEFT_TM6605_CHANNEL=1
SMARTBAG_RIGHT_TM6605_CHANNEL=2
SMARTBAG_ENABLE_RIGHT_TM6605=1
# Set to the copied MR20 configuration; the controller leaves radar disabled if this file is absent.
SMARTBAG_MR20_CONFIG=/root/smartbag_alert/config/mr20_radar.json

# Keep disabled until the OM runner emits one of:
#   {"type":"vision_alert","side":"left","level":1,"score":0.5,"track_id":1,"ts":1.0}
#   level=1..4
#   AL L1 / AL R4
SMARTBAG_ENABLE_OM_BRIDGE=0
SMARTBAG_LEFT_RUNNER=
SMARTBAG_RIGHT_RUNNER=
SMARTBAG_LEFT_DETECTOR=
SMARTBAG_RIGHT_DETECTOR=
