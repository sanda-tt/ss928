page { min-height: 100vh; background: #f3f5f7; color: #17212b; }
.dashboard { box-sizing: border-box; min-height: 100vh; padding: 34rpx 28rpx 56rpx; }.dashboard__header { display: flex; align-items: flex-start; justify-content: space-between; gap: 22rpx; margin-bottom: 22rpx; }.dashboard__title { color: #101820; font-size: 42rpx; font-weight: 700; line-height: 1.2; }.dashboard__subtitle { margin-top: 10rpx; color: #66717d; font-size: 24rpx; line-height: 1.4; word-break: break-all; }.dashboard__status { flex-shrink: 0; max-width: 290rpx; min-height: 52rpx; box-sizing: border-box; padding: 10rpx 18rpx; border-radius: 8rpx; background: #e7ecef; color: #41505c; font-size: 22rpx; line-height: 32rpx; text-align: center; }.dashboard__status--connected { background: #dff5ed; color: #09664c; }.dashboard__status--offline { background: #e7ecef; color: #66717d; }
.mode-switch { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-bottom: 22rpx; }.mode-switch__item { display: flex; align-items: center; justify-content: center; height: 70rpx; margin: 0; padding: 0 22rpx; border-radius: 8rpx; background: #fff; color: #25313b; font-size: 26rpx; line-height: 70rpx; box-shadow: inset 0 0 0 2rpx #d9e0e6; }.mode-switch__item--active { background: #0b7f78; color: #fff; box-shadow: none; }
.current-panel, .pose-frame { box-sizing: border-box; margin-bottom: 24rpx; padding: 22rpx; border-radius: 8rpx; background: #fff; box-shadow: inset 0 0 0 2rpx #e1e7ec; }.current-panel__label { color: #66717d; font-size: 24rpx; }.current-panel__value { margin-top: 10rpx; font-size: 50rpx; font-weight: 700; line-height: 62rpx; }.current-panel__value--good { color: #0a7a50; }.current-panel__value--bad { color: #c64237; }.current-panel__value--unworn, .current-panel__value--unknown { color: #66717d; }.current-panel__detail { margin-top: 8rpx; color: #53616e; font-size: 24rpx; line-height: 34rpx; }
.pose-frame { min-height: 360rpx; position: relative; overflow: hidden; }.pose-frame--good { background: #dff5ed; box-shadow: inset 0 0 0 3rpx #18a058; }.pose-frame--bad { background: #ffe9e6; box-shadow: inset 0 0 0 3rpx #e5534b; }.pose-frame--unworn, .pose-frame--unknown { background: #eef2f4; box-shadow: inset 0 0 0 3rpx #c7d0d7; }.pose-frame__badge { position: absolute; left: 22rpx; top: 20rpx; z-index: 2; padding: 10rpx 18rpx; border-radius: 8rpx; background: rgba(255,255,255,.86); color: #17212b; font-size: 26rpx; font-weight: 700; }.pose-frame__body { position: absolute; left: 50%; top: 92rpx; width: 210rpx; height: 220rpx; margin-left: -105rpx; }.pose-frame__head { width: 70rpx; height: 70rpx; margin: 0 auto; border-radius: 35rpx; background: #17212b; }.pose-frame__torso { width: 86rpx; height: 132rpx; margin: 8rpx auto 0; border-radius: 34rpx 34rpx 18rpx 18rpx; background: #17212b; transform-origin: 50% 10%; }.pose-frame__torso--good { transform: rotate(0deg); }.pose-frame__torso--bad { transform: rotate(18deg); }.pose-frame__torso--unworn, .pose-frame__torso--unknown { background: #87939e; }.pose-frame__bag { position: absolute; left: 118rpx; top: 94rpx; width: 72rpx; height: 98rpx; border-radius: 22rpx; background: #2f80ed; box-shadow: inset 0 -12rpx 0 rgba(0,0,0,.12); }.update-line { color: #66717d; font-size: 23rpx; line-height: 34rpx; text-align: center; }.reminder-line { margin-top: 12rpx; color: #d98200; font-size: 24rpx; font-weight: 700; line-height: 34rpx; text-align: center; }
.history-panel { margin-top: 22rpx; padding: 20rpx; border-radius: 8rpx; background: #fff; box-shadow: inset 0 0 0 2rpx #e1e7ec; }.history-panel__title { font-size: 28rpx; font-weight: 700; }.history-panel__empty { padding: 22rpx 0 4rpx; color: #66717d; font-size: 24rpx; }.history-item { display: flex; justify-content: space-between; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid #edf1f3; color: #53616e; font-size: 23rpx; line-height: 32rpx; }.history-item:last-child { border-bottom: 0; }
