<view class="page">
  <view class="topbar"><view><view class="title">姿态分析</view><view class="subtitle">{{deviceLabel}}</view></view><view class="status status--{{statusLevel}}">{{statusText}}</view></view>
  <view class="mode-switch"><button class="mode-switch__item mode-switch__item--active">姿态分析</button><button class="mode-switch__item" bindtap="goMonitor">实时姿态</button></view>
  <view class="panel analysis-panel"><view class="panel__head"><view class="panel__title">今日姿态分析</view><view class="panel__meta">云端每日汇总</view></view><view class="analysis-layout"><canvas class="analysis-pie" canvas-id="posturePie" width="180" height="180"></canvas><view class="analysis-stats"><view class="analysis-stat analysis-stat--good"><view class="analysis-stat__value">{{stats.goodPercent}}%</view><view class="analysis-stat__label">良好姿态</view></view><view class="analysis-stat analysis-stat--bad"><view class="analysis-stat__value">{{stats.badPercent}}%</view><view class="analysis-stat__label">不良姿态</view></view></view></view></view>
  <view class="panel daily-panel"><view class="panel__head"><view class="panel__title">今日累计时长</view><view class="panel__meta">更新于 {{stats.updatedTime}}</view></view><view wx:if="{{dataMessage}}" class="daily-panel__empty">{{dataMessage}}</view><view wx:else class="duration-grid"><view class="duration-card"><view class="duration-card__label">今日有效佩戴时长</view><view class="duration-card__value">{{stats.wearingDuration}}</view></view><view class="duration-card duration-card--good"><view class="duration-card__label">良好姿态时长</view><view class="duration-card__value">{{stats.goodDuration}}</view></view><view class="duration-card duration-card--bad"><view class="duration-card__label">不良姿态时长</view><view class="duration-card__value">{{stats.badDuration}}</view></view></view></view>
</view>
