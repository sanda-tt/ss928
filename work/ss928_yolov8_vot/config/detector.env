# Factory artifact and fixed model contract discovered on the SS928 board.
MODEL_PATH=/opt/sample/yolov8/yolov8n.om
MODEL_WIDTH=640
MODEL_HEIGHT=640
MODEL_INPUT_FORMAT=NV12
CONFIDENCE=0.25
NMS=0.45
MAX_DETECTIONS=50
TARGET_CLASSES=car,bicycle,motorcycle,bus,truck

# VOT calibration defaults.  These are not accepted calibration results.
CAMERA_HEIGHT_M=1.2
CAMERA_PITCH_DEG=5
CAMERA_FOV_DEG=120
CAMERA_FOV_TYPE=diagonal
DISTANCE_MODE=fused

# The planned camera is described by the user as 120-degree, 2K, wide-angle,
# and distortion-free.  Its exact UVC mode and residual lens distortion must
# still be measured on the attached unit.
CAMERA_DEVICE=/dev/video0
CAMERA_WIDTH=0
CAMERA_HEIGHT=0
CAMERA_FPS=0
CAMERA_DECLARED_FOV_DEG=120
CALIBRATION_ACCEPTED=0
ENABLE_STAGE_J=0
