<view class="tracks">
  <view class="map-shell">
    <map
      id="trackMap"
      class="track-map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      polyline="{{polyline}}"
      show-location
    ></map>

    <cover-view class="map-status map-status--{{statusLevel}}">
      <cover-view class="map-status__main">{{statusText}} · 实时推送开启</cover-view>
      <cover-view class="map-status__sub">{{deviceLabel}}</cover-view>
    </cover-view>

    <cover-view class="map-toolbar">
      <cover-view class="map-toolbar__pill">四川成都人民公园</cover-view>
      <cover-view class="map-toolbar__pill">{{pointCount}} 点</cover-view>
      <cover-view class="map-toolbar__pill">{{accuracyText}}</cover-view>
    </cover-view>
  </view>

  <view class="summary-panel">
    <view class="summary-panel__head">
      <view>
        <view class="summary-panel__title">{{currentTrackLabel}}</view>
        <view class="summary-panel__meta">{{latestMeta}}</view>
      </view>
      <view class="summary-panel__badge">{{pointCount}} 点</view>
    </view>
    <view class="summary-grid">
      <view class="summary-grid__item">
        <text>地图点数</text>
        <strong>{{displayCount}}</strong>
      </view>
      <view class="summary-grid__item">
        <text>实时推送</text>
        <strong>{{liveEnabled ? '开启' : '关闭'}}</strong>
      </view>
      <view class="summary-grid__item">
        <text>定位精度</text>
        <strong>{{accuracyText}}</strong>
      </view>
      <view class="summary-grid__item">
        <text>移动速度</text>
        <strong>{{speedText}}</strong>
      </view>
    </view>
    <view class="command-line">{{commandResponse}}</view>
  </view>

  <view class="panel">
    <view class="panel__title">最近位置记录</view>
    <view class="recent-row" wx:for="{{recentPoints}}" wx:key="id">
      <view class="recent-row__time">{{item.time}}</view>
      <view class="recent-row__main">
        <view class="recent-row__location">{{item.location}}</view>
        <view class="recent-row__meta">{{item.meta}}</view>
      </view>
    </view>
  </view>
</view>
