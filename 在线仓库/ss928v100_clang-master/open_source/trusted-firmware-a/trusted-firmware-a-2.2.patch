diff --git a/plat/vendor/ss928v100/aarch64/plat_helpers.S b/plat/vendor/ss928v100/aarch64/plat_helpers.S
new file mode 100644
index 0000000..ee75964
--- /dev/null
+++ b/plat/vendor/ss928v100/aarch64/plat_helpers.S
@@ -0,0 +1,403 @@
+/*
