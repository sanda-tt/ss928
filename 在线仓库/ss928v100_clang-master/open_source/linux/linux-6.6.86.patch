+u32 sdhci_nebula_irq(struct sdhci_host *host, u32 intmask)
+{
+#ifdef CONFIG_SDHCI_NEBULA_DFX
+	sdhci_nebula_dfx_irq(host, intmask);
+#endif
+
+	if (host->mmc->caps2 & MMC_CAP2_CQE)
+		return nebula_cqe_irq(host, intmask);
+
