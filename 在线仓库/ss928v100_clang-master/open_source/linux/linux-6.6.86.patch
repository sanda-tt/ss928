+ * along with this program; if not, see
+ * <https://www.gnu.org/licenses/>.
+ */
+
+#ifndef __PERIPH_IO_H
+#define __PERIPH_IO_H
+
+#include <asm/io.h>
+#include <linux/types.h>
+
+enum bsp_peri_type {
+	BSP_PERI_NONE = 0,
+	BSP_PERI_SDIO,
+	BSP_PERI_MMC,
+	BSP_PERI_USB,
+	BSP_PERI_SATA,
+	BSP_PERI_GMAC
+};
+
+unsigned long bsp_peri_lock(enum bsp_peri_type type);
+void bsp_peri_unlock(unsigned long flags, enum bsp_peri_type type);
+
+#define BSP_PERI_DEF_READ(fn, n_bits)		\
+static inline u##n_bits bsp_peri_##fn(		\
+	const volatile void __iomem *addr,	\
+	enum bsp_peri_type type)		\
+{ 						\
+	u##n_bits val;				\
+	unsigned long flags;			\
+	flags = bsp_peri_lock(type);		\
+	val = fn(addr);				\
+	bsp_peri_unlock(flags, type);		\
+	return val;				\
+}
+
+#define BSP_PERI_DEF_WRITE(fn, n_bits)		\
+static inline void bsp_peri_##fn(u##n_bits val,	\
+	volatile void __iomem *addr,		\
+	enum bsp_peri_type type)		\
+{ 						\
+	unsigned long flags;			\
+	flags = bsp_peri_lock(type);		\
+	fn(val, addr);				\
+	bsp_peri_unlock(flags, type);		\
+}
+
+#define BSP_PERI_DEF_READ_REP(fn)		\
+static inline void bsp_peri_##fn(		\
+	const volatile void __iomem *addr,	\
+	void *buffer, unsigned int count,	\
+	enum bsp_peri_type type)		\
+{						\
+	unsigned long flags;			\
+	flags = bsp_peri_lock(type);		\
+	fn(addr, buffer, count);		\
+	bsp_peri_unlock(flags, type);		\
+}
+
+#define BSP_PERI_DEF_WRITE_REP(fn)		\
+static inline void bsp_peri_##fn(		\
+	volatile void __iomem *addr,	\
+	const void *buffer, unsigned int count,	\
+	enum bsp_peri_type type)		\
+{						\
+	unsigned long flags;			\
+	flags = bsp_peri_lock(type);		\
+	fn(addr, buffer, count);		\
+	bsp_peri_unlock(flags, type);		\
+}
+
+BSP_PERI_DEF_READ(readb, 8)
+BSP_PERI_DEF_READ(readw, 16)
+BSP_PERI_DEF_READ(readl, 32)
+BSP_PERI_DEF_READ(readq, 64)
+
+BSP_PERI_DEF_WRITE(writeb, 8)
+BSP_PERI_DEF_WRITE(writew, 16)
+BSP_PERI_DEF_WRITE(writel, 32)
+BSP_PERI_DEF_WRITE(writeq, 64)
+
+BSP_PERI_DEF_READ(ioread8, 8)
+BSP_PERI_DEF_READ(ioread16, 16)
+BSP_PERI_DEF_READ(ioread32, 32)
+BSP_PERI_DEF_READ(ioread64, 64)
+
+BSP_PERI_DEF_WRITE(iowrite8, 8)
+BSP_PERI_DEF_WRITE(iowrite16, 16)
+BSP_PERI_DEF_WRITE(iowrite32, 32)
+BSP_PERI_DEF_WRITE(iowrite64, 64)
+
+BSP_PERI_DEF_READ_REP(ioread8_rep)
+BSP_PERI_DEF_READ_REP(ioread16_rep)
+BSP_PERI_DEF_READ_REP(ioread32_rep)
+BSP_PERI_DEF_READ_REP(ioread64_rep)
+
+BSP_PERI_DEF_WRITE_REP(iowrite8_rep)
+BSP_PERI_DEF_WRITE_REP(iowrite16_rep)
+BSP_PERI_DEF_WRITE_REP(iowrite32_rep)
+BSP_PERI_DEF_WRITE_REP(iowrite64_rep)
+
+#endif /* __PERIPH_IO_H */
+
