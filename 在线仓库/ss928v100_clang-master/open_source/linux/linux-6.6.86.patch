+				       struct mtd_oob_region *oobregion)
+{
+	if (section)
+		return -ERANGE;
+
+	oobregion->length = OOB_LENGTH_2K16BIT;
+	oobregion->offset = OOB_OFFSET_2K16BIT;
+
+	return 0;
+}
