+
+	if (msg->flags & I2C_M_RD) {
+		debug_dump_i2c_msg(i2c->msg);
+		mb();
+		dma_dst_addr = dma_map_single(i2c->dev, msg->buf,
+					      msg->len, DMA_FROM_DEVICE);
