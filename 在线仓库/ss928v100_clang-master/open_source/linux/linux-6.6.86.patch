diff --git a/drivers/vendor/cma/cma.c b/drivers/vendor/cma/cma.c
new file mode 100644
index 0000000..acb1761
--- /dev/null
+++ b/drivers/vendor/cma/cma.c
@@ -0,0 +1,190 @@
+/*
