+void sdhci_nebula_hw_reset(struct sdhci_host *host)
+{
+	unsigned int reg;
+	reg = sdhci_readl(host, SDHCI_EMMC_HW_RESET);
+	reg &= ~SDHCI_EMMC_RST_N;
+	sdhci_writel(host, reg, SDHCI_EMMC_HW_RESET);
+
+	udelay(10); /* delay 10 us */
+
+	reg = sdhci_readl(host, SDHCI_EMMC_HW_RESET);
+	reg |= SDHCI_EMMC_RST_N;
+	sdhci_writel(host, reg, SDHCI_EMMC_HW_RESET);
+
+	udelay(200); /* delay 200 us */
+}
