+	bool "Vendor Flash Memory Controller v100 Nand devices support"
+	depends on MFD_BSP_FMC && !MTD_SPI_NAND_BSP
+	select MISC_FILESYSTEMS
+	select MTD_BLOCK
+	select YAFFS_FS
+	select YAFFS_YAFFS2
