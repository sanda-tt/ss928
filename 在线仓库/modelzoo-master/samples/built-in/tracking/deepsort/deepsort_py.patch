+# 强制修复 Upsample 缺失属性的全局补丁
+def patched_forward(self, input):
+    if not hasattr(self, 'recompute_scale_factor'):
+        self.recompute_scale_factor = None
+    return self._orig_forward(input)
+
+if not hasattr(nn.Upsample, '_orig_forward'):
+    nn.Upsample._orig_forward = nn.Upsample.forward
+    nn.Upsample.forward = patched_forward
+
