+import torch
+import torch.nn as nn
+import torch.nn.functional as F
+
+class LayerNorm(nn.Module):
+    """
+    完整的LayerNorm实现，与torch.nn.LayerNorm功能完全一致
+    """
+    
+    def __init__(self, normalized_shape, eps=1e-12, elementwise_affine=True):
+        """
+        Args:
+            normalized_shape: 需要归一化的维度形状
+            eps: 防止除零的小常数
+            elementwise_affine: 是否使用可学习的缩放和偏移参数
+        """
+        super().__init__()  
+        
+        # 处理输入参数
+        if isinstance(normalized_shape, int):
+            normalized_shape = (normalized_shape,)
+        
+        self.normalized_shape = tuple(normalized_shape)
+        self.eps = eps
+        self.elementwise_affine = elementwise_affine
+        
+        # 初始化可学习参数
+        if self.elementwise_affine:
+            self.weight = nn.Parameter(torch.ones(self.normalized_shape))
+            self.bias = nn.Parameter(torch.zeros(self.normalized_shape))
+        else:
+            self.register_parameter('weight', None)
+            self.register_parameter('bias', None)
+    
+    def forward(self, x):
+        """
+        Args:
+            x: 输入张量，最后几个维度必须与normalized_shape匹配
+        Returns:
+            归一化后的张量
+        """
+        # 计算需要归一化的维度索引
+        normalized_dims = tuple(range(-len(self.normalized_shape), 0))
+        
+        # 检查输入形状
+        input_shape = x.shape
+        expected_shape = input_shape[-len(self.normalized_shape):]
+        assert expected_shape == self.normalized_shape, \
+            f"期望最后{len(self.normalized_shape)}维形状为{self.normalized_shape}，实际为{expected_shape}"
+        
+        # 计算均值和方差
+        # keepdim=True 保持维度以便广播
+        mean = x.mean(dim=normalized_dims, keepdim=True)
+        var = x.var(dim=normalized_dims, keepdim=True, unbiased=False)  # 使用有偏估计
+        
+        # 归一化
+        x_normalized = (x - mean) / torch.sqrt(var + self.eps)
+        
+        # 应用可学习参数
+        if self.elementwise_affine:
+            output = self.weight * x_normalized + self.bias
+        else:
+            output = x_normalized
+        
+        return output
+    
+    def extra_repr(self):
+        """返回模块的额外信息"""
+        return f'{self.normalized_shape}, eps={self.eps}, ' \
+               f'elementwise_affine={self.elementwise_affine}'
+# BertLayerNorm = torch.nn.LayerNorm
+BertLayerNorm = LayerNorm
 
