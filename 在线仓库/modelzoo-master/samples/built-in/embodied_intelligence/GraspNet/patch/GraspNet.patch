+import torch
+import torch_npu
+import os
+import sys
+import numpy as np
+
+modelzoo_ops_path = os.getenv('ASCEND_CUSTOM_OPP_PATH')
+if modelzoo_ops_path:
+    sys.path.append(os.path.join(modelzoo_ops_path, 'framework'))
+
+from modelzoo_ops.ops.group_points import group_points
+from modelzoo_ops.ops.cylinder_query import cylinder_query
+from modelzoo_ops.ops.furthest_point_sampling import furthest_point_sampling
+
+def npu_gather_points(points: torch.Tensor, idx: torch.Tensor) -> torch.Tensor:
+    """
+    从输入点云中根据索引收集点
+
+    points (torch.Tensor): 输入点云，shape为(B, C, N)
+    idx (torch.Tensor): 索引，shape为(B, M)
+
+    out (torch.Tensor): 收集的点，shape为(B, C, M)
+    """
+    B, C, N = points.size()
+    M = idx.size(1)
+    idx = idx.unsqueeze(1).repeat(1, C, 1) # 扩展索引以匹配通道维度
+    out = torch.gather(points, 2, idx)
+    return out
+
+def npu_gather_points_grad(grad_out: torch.Tensor, idx: torch.Tensor, n: int) -> torch.Tensor:
+    """
+    计算 gather_points 操作的梯度
+
+    grad_out (torch.Tensor): 输出的梯度，shape为(B, C, M)
+    idx (torch.Tensor): 索引，shape为(B, M)
+    n (int): 输入的点云数量
+
+    grad_points (torch.Tensor): 输入的梯度，shape为(B, C, N)
+    """
+    B, C, N = grad_out.size()
+    grad_points = torch.zeros((B, C, N), device=grad_out.device, dtype=grad_out.dtype)
+    grad_out = grad_out.contiguous()
+    idx = idx.unsqueeze(1).repeat(1, C, 1) # 扩展索引以匹配通道维度
+    grad_points.scatter_add_(2, idx, grad_out)
+    return grad_points
+
+def npu_furthest_point_sampling(xyz: torch.Tensor, npoint: int) -> torch.Tensor:
+    """
+    最远点采样
+
+    xyz (torch.Tensor): 输入点云，shape为 (B, N, 3)
+    npoint (int): 采样点的数量
+
+    out (torch.Tensor): 采样点的索引，shape为 (B, npoint)
+    """
+    return furthest_point_sampling(xyz, npoint)
+
+def npu_three_nn(unknowns: torch.Tensor, knows: torch.Tensor) -> tuple:
+    """
+    对每个未知点，找出距离最近的三个已知点及其距离平方
+
+    unknowns (torch.Tensor): shape为 (B, N, 3)的未知点张量
+    knows (torch.Tensor): shape为 (B, M, 3)的已知点张量
+
+    tuple: 包含距离平方 (B, N, 3)和索引 (B, M, 3)的元组
+    """
+    B, N, _ = unknowns.size()
+    M = knows.size(1)
+    # 扩展维度以广播计算距离
+    unknowns_expanded = unknowns.unsqueeze(2).repeat(1, 1, M, 1) # (B, N, M, 3)
+    knows_expanded = knows.unsqueeze(1).repeat(1, N, 1, 1) # (B, N, M, 3)
+    # 计算距离平方
+    dist2 = torch.sum((unknowns_expanded - knows_expanded) ** 2, dim = -1) # (B, N, M)
+    # 获取距离最小的三个点的距离和索引
+    dist2_topk, idx = torch.topk(dist2.float(), k = 3, dim = 2, largest = False) # (B, N, 3)
+    return dist2_topk, idx.int()
+
+def npu_three_interpolate(points: torch.Tensor, idx: torch.Tensor, weight: torch.Tensor) -> torch.Tensor:
+    """
+    根据三个最近点及其权重进行插值
+
+    points (torch.Tensor): 点特征张量，shape为(B, C, M)
+    idx (torch.Tensor): 索引张量，shape为(B, N, 3)
+    weight (torch.Tensor): 权重张量，shape为(B, N, 3)
+
+    out (torch.Tensor): 插值结果张量，shape为(B, C, N)
+    """
+    B, C, M = points.size()
+    N = idx.size(1)
+    # 扩展权重维度以匹配特征维度
+    weight = weight.unsqueeze(1).repeat(1, C, 1, 1) # (B, C, N, 3)
+    expand_n = N * 3
+    # 扩展points维度以匹配索引张量维度
+    points_expanded = points.unsqueeze(-1).repeat(1, 1, 1, expand_n) # (B, C, M, N * 3)
+    points_expanded = points_expanded.view(B, C, M, N, 3) # (B, C, M, N, 3)
+
+    # 扩展索引维度
+    idx_expanded = idx.unsqueeze(1).repeat(1, C, 1, 1) # (B, C, N, 3)
+    idx_expanded = idx_expanded.unsqueeze(2) # (B, C, 1, N, 3)
+
+    # 根据索引获取对应点的特征
+    points_gathered = torch.gather(points_expanded, 2, idx_expanded) # (B, C, 1, N, 3)
+    points_gathered = points_gathered[:, :, 0, :, :] # (B, C, N, 3)
+
+    # 加权求和
+    out = (points_gathered * weight).sum(dim = -1) # (B, C, N)
+    return out
+
+def npu_three_interpolate_grad(grad_out: torch.Tensor, idx: torch.Tensor, weight: torch.Tensor, M: int) -> torch.Tensor:
+    """
+    计算three_interpolate操作的梯度
+
+    grad_out (torch.Tensor): 输出梯度张量，shape为(B, C, N)
+    idx (torch.Tensor): 索引张量，shape为(B, N, 3)
+    weight (torch.Tensor): 权重张量，shape为(B, N, 3)
+    M (int): 输入点的数量
+
+    grad_points (torch.Tensor): 输入梯度张量，shape为(B, C, M)
+    """
+    B, C, N = grad_out.size()
+    # 扩展梯度和权重维度
+    grad_out_expanded = grad_out.unsqueeze(-1).repeat(1, 1, 1, 3) # (B, C, N, 3)
+    weight_expanded = weight.unsqueeze(1).repeat(1, C, 1, 1) # (B, C, N, 3)
+    # 计算每个点的梯度贡献
+    grad_contribution = grad_out_expanded * weight_expanded # (B, C, N, 3)
+    # 初始化输入梯度
+    grad_points = torch.zeros((B, C, M), device=grad_out.device, dtype=grad_out.dtype)
+    # 累加梯度
+    grad_points.scatter_add_(2, idx.unsqueeze(1).repeat(1, C, 1, 1), grad_contribution)
+    return grad_points
+
+def npu_group_points(points: torch.Tensor, idx: torch.Tensor) -> torch.Tensor:
+    """
+    根据索引对特征进行分组操作
+
+    points (torch.Tensor): 输入特征，shape为(B, C, N)
+    idx (torch.Tensor): 索引张量，shape为(B, npoint, nsample)
+
+    output (torch.Tensor): 分组后的特征，shape为(B, C, npoint, nsample)
+    """
+    return group_points(points, idx)
+
+def npu_ball_query(radius: float, nsample: int, xyz: torch.Tensor, new_xyz: torch.Tensor) -> torch.Tensor:
+    """
+    在给定点云中查询每个点的球形邻域内的点
+
+    radius (float): 球形邻域半径
+    nsample (int): 每个查询点最多采样点数
+    xyz (torch.Tensor): 输入点云坐标，shape为(B, N, 3)
+    new_xyz (torch.Tensor): 查询点坐标，shape为(B, M, 3)
+
+    out (torch.Tensor): 邻域点索引，shape为(B, M, nsample)
+    """
+
+    assert new_xyz.is_contiguous() and xyz.is_contiguous(), "输入张量必须连续存储"
+    assert new_xyz.dtype == torch.float32 and xyz.dtype == torch.float32, "输入张量必须为 float32 类型"
+
+    B, M, _ = new_xyz.size()
+    N = xyz.size(1)
+
+    new_xyz_expanded = new_xyz.unsqueeze(2).repeat(1, 1, N, 1) # (B, M, N, 3)
+    xyz_expanded = xyz.unsqueeze(1).repeat(1, M, 1, 1) # (B, M, N, 3)
+    dist2 = torch.sum((new_xyz_expanded - xyz_expanded) ** 2, dim = -1) # (B, M, N)
+    radius2 = radius * radius
+
+    # 标记有效点（距离 < 半径平方）
+    valid_mask = dist2 < radius2 # (B, M, N), True表示有效点
+
+    # 计算每个查询点的有效点累积计数（按点云原始顺序）
+    valid_count = torch.cumsum(valid_mask.int(), dim = 2).int() # (B, M, N), 累积有效点数
+
+    # 筛选前 nsample 个有效点（按原始顺序，非距离排序）
+    select_mask = (valid_count <= nsample) & valid_mask # (B, M, N), True表示选中的有效点
+
+    # 获取选中点的索引（按原始点云顺序）
+    indices = torch.arange(N, device=xyz.device).unsqueeze(0).unsqueeze(0).repeat(B, M, 1)
+    # 仅保留选中点的索引，其余位置置为-1
+    select_indices = torch.where(select_mask, indices, torch.tensor(-1, device=xyz.device))
+
+    # 提取前 nsample 个有效索引（补全 -1），此处topk 按位置排序，而非距离
+    values, pos = torch.topk(select_mask.float(), k = nsample, dim = 2, largest = True) # pos为选中点在N维的索引
+
+    idx = torch.gather(select_indices.int(), dim = 2, index = pos) # (B, M, nsample)
+
+    first_val = pos[:, :, 0].int().unsqueeze(-1).repeat(1, 1, nsample)
+    select_mask = (idx > 0)
+    out = torch.where(select_mask, idx, first_val)
+
+    out = torch.clip(out.float(), 0, N - 1) # 增加index边界检查
+    return out.to(torch.int)
+
+def npu_cylinder_query(new_xyz: torch.Tensor, xyz: torch.Tensor, rot: torch.Tensor, radius: float, hmin: float, hmax: float, nsample: int) -> torch.Tensor:
+    """
+    在给定点云中查询每个点在指定旋转圆柱领域内的点
+
+    new_xyz (torch.Tensor): 查询点坐标，shape为(B, M, 3)
+    xyz (torch.Tensor): 输入点云坐标，shape为(B, N, 3)
+    rot (torch.Tensor): 旋转矩阵张量，shape为(B, M, 9)
+    radius (float): 圆柱底面半径
+    hmin (float): 圆柱的最小高度
+    hmax (float): 圆柱的最大高度
+    nsample (int): 每个查询点最多采样点数
+
+    out (torch.Tensor): 每个查询点邻域内点的索引，shape为(B, M, nsample)
+    """
+    return cylinder_query(new_xyz, xyz, rot, radius, hmin, hmax, nsample)
