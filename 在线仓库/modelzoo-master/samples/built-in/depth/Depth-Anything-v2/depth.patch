+"""
+class Mlp(nn.Module):
+    def __init__(
+        self,
+        in_features: int,
+        hidden_features: Optional[int] = None,
+        out_features: Optional[int] = None,
+        act_layer: Callable[..., nn.Module] = nn.GELU,
+        drop: float = 0.0,
+        bias: bool = True,
+    ) -> None:
+        super().__init__()
+        out_features = out_features or in_features
+        hidden_features = hidden_features or in_features
+        self.fc1 = nn.Conv2d(in_features, hidden_features, kernel_size=1,  bias=bias)
+        self.act = act_layer()
+        self.fc2 = nn.Conv2d(hidden_features, out_features, kernel_size=1, bias=bias)
+        self.drop = nn.Dropout(drop)
+
+    def forward(self, x: Tensor) -> Tensor:
+        x = x.permute(0, 2, 1).unsqueeze(2)
+        x = self.fc1(x)
+        x = self.act(x)
+        x = self.drop(x)
+        x = self.fc2(x)
+        x = self.drop(x)
+        x = x.squeeze(2).permute(0, 2, 1)
+        return x
+
+    def _load_from_state_dict(
+        self,
+        state_dict,
+        prefix,
+        local_metadata,
+        strict,
+        missing_keys,
+        unexpected_keys,
+        error_msgs,
+            
+    ):
+        fc1_w_key = prefix + "fc1.weight"
+        if fc1_w_key in state_dict and state_dict[fc1_w_key].dim()==2:
+            state_dict[fc1_w_key] = state_dict[fc1_w_key].unsqueeze(-1).unsqueeze(-1)
+        
+        fc2_w_key = prefix + "fc2.weight"
+        if fc2_w_key in state_dict and state_dict[fc2_w_key].dim()==2:
+            state_dict[fc2_w_key] = state_dict[fc2_w_key].unsqueeze(-1).unsqueeze(-1)
+        
+        super()._load_from_state_dict(
+            state_dict,
+            prefix,
+            local_metadata,
+            strict,
+            missing_keys,
+            unexpected_keys,
+            error_msgs,
+        )
