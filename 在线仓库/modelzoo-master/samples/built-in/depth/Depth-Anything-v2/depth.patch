@@ -60,6 +60,76 @@ class Attention(nn.Module):
         x = self.proj(x)
         x = self.proj_drop(x)
         return x
+"""
+
+class Attention(nn.Module):
+    def __init__(
+        self,
+        dim: int,
+        num_heads: int = 8,
+        qkv_bias: bool = False,
+        proj_bias: bool = True,
+        attn_drop: float = 0.0,
+        proj_drop: float = 0.0,
+    ) -> None:
+        super().__init__()
+        self.num_heads = num_heads
+        head_dim = dim // num_heads
+        self.scale = head_dim**-0.5
+
+        self.qkv = nn.Conv2d(dim, dim * 3, kernel_size=1, bias=qkv_bias)
+        self.attn_drop = nn.Dropout(attn_drop)
+        self.proj = nn.Conv2d(dim, dim, kernel_size=1, bias=proj_bias)
+        self.proj_drop = nn.Dropout(proj_drop)
+
+    def forward(self, x: Tensor) -> Tensor:
+        B, N, C = x.shape
+        x_=x.permute(0,2,1).unsqueeze(2) #(B, C, 1, N)
+
+        qkv = self.qkv(x_).squeeze(2).permute(0,2,1).reshape(B, N, 3, self.num_heads, C // self.num_heads)
+        qkv = qkv.permute(2, 0, 3, 1, 4)
+
+        q, k, v = qkv[0] * self.scale, qkv[1], qkv[2]
+        attn = q @ k.transpose(-2, -1)
+
+        attn = attn.softmax(dim=-1)
+        attn = self.attn_drop(attn)
+
+        x = (attn @ v).transpose(1, 2).reshape(B, N, C)
+
+        x_ = x.permute(0,2,1).unsqueeze(2)
+        x_ = self.proj(x_).squeeze(2).permute(0, 2, 1)
+        x_ = self.proj_drop(x_)
+        return x_
+
+    def _load_from_state_dict(
+        self,
+        state_dict,
+        prefix,
+        local_metadata,
+        strict,
+        missing_keys,
+        unexpected_keys,
+        error_msgs,
+            
+    ):
+        qkv_w_key = prefix + "qkv.weight"
+        if qkv_w_key in state_dict and state_dict[qkv_w_key].dim()==2:
+            state_dict[qkv_w_key] = state_dict[qkv_w_key].unsqueeze(-1).unsqueeze(-1)
+        
+        proj_w_key = prefix + "proj.weight"
+        if proj_w_key in state_dict and state_dict[proj_w_key].dim()==2:
+            state_dict[proj_w_key] = state_dict[proj_w_key].unsqueeze(-1).unsqueeze(-1)
+        
+        super()._load_from_state_dict(
+            state_dict,
+            prefix,
+            local_metadata,
+            strict,
+            missing_keys,
+            unexpected_keys,
+            error_msgs,
+        )
 
 
