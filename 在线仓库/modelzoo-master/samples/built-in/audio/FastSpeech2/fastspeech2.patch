+class MultiHeadAttention(nn.Module):
+    """ Multi-Head Attention module with Conv2d replacing Linear """
+
+    def __init__(self, n_head, d_model, d_k, d_v, dropout=0.1):
+        super().__init__()
+
+        self.n_head = n_head
+        self.d_k = d_k
+        self.d_v = d_v
+
+        # === 把 Linear 换成 Conv2d(kernel=1) ===
+        self.w_qs = nn.Conv2d(d_model, n_head * d_k, kernel_size=1, bias=True)
+        self.w_ks = nn.Conv2d(d_model, n_head * d_k, kernel_size=1, bias=True)
+        self.w_vs = nn.Conv2d(d_model, n_head * d_v, kernel_size=1, bias=True)
+
+        self.attention = ScaledDotProductAttention(temperature=np.power(d_k, 0.5))
+        self.layer_norm = nn.LayerNorm(d_model)
+
+        self.fc = nn.Conv2d(n_head * d_v, d_model, kernel_size=1, bias=True)
+
+        self.dropout = nn.Dropout(dropout)
+
+    def forward(self, q, k, v, mask=None):
+        d_k, d_v, n_head = self.d_k, self.d_v, self.n_head
+        sz_b, len_q, ad_q = q.data.size()
+        sz_b, len_k, ad_k = k.data.size()
+        sz_b, len_v, ad_v = v.data.size()
+
+        residual = q
+
+        # ==== [B, L, C] → [b, c, 1, l] ====
+        q = q.permute(0, 2, 1).unsqueeze(-2)
+        k = k.permute(0, 2, 1).unsqueeze(-2)
+        v = v.permute(0, 2, 1).unsqueeze(-2)
+
+        # ==== Conv2d 等效 Linear ====
+        q = self.w_qs(q).reshape(sz_b, ad_q, len_q).permute(0, 2, 1)  # [B, L, n_head*d_k]
+        k = self.w_ks(k).reshape(sz_b, ad_k, len_k).permute(0, 2, 1)
+        v = self.w_vs(v).reshape(sz_b, ad_v, len_v).permute(0, 2, 1)
+
+        # ==== reshape 进入 attention ====
+        q = q.view(sz_b, len_q, n_head, d_k).permute(2, 0, 1, 3).contiguous().view(-1, len_q, d_k)
+        k = k.view(sz_b, len_k, n_head, d_k).permute(2, 0, 1, 3).contiguous().view(-1, len_k, d_k)
+        v = v.view(sz_b, len_v, n_head, d_v).permute(2, 0, 1, 3).contiguous().view(-1, len_v, d_v)
+
+        # if mask is not None:
+        mask = mask.repeat(n_head, 1, 1)
+
+        output, attn = self.attention(q, k, v, mask=mask)
+
+        # ==== reshape 回来 ====
+        output = output.view(n_head, sz_b, len_q, d_v)
+        output = output.permute(1, 2, 0, 3).contiguous().view(sz_b, len_q, -1)
+
+        # ==== fc (Conv2d 版本) ====
+        output = output.permute(0, 2, 1).unsqueeze(-2)  # [B, d_model, L, 1]
+        output = self.fc(output).reshape(sz_b, ad_q, len_q).permute(0, 2, 1)  # [B, L, d_model]
+
+        output = self.dropout(output)
+        output = self.layer_norm(output + residual)
+
+        return output, attn
+
+    def _load_from_state_dict(
+            self,
+            state_dict,
+            prefix,
+            local_metadata,
+            strict,
+            missing_keys,
+            unexpected_keys,
+            error_msgs,
+    ):
+        # 处理 qkv
+        ks = ['w_qs', 'w_ks', 'w_vs', 'fc']
+        for k in ks:
+            w_key = prefix + f"{k}.weight"
+            if w_key in state_dict and state_dict[w_key].dim() == 2:
+                state_dict[w_key] = state_dict[w_key].unsqueeze(-1).unsqueeze(-1)
+
+        super()._load_from_state_dict(
+            state_dict,
+            prefix,
+            local_metadata,
+            strict,
+            missing_keys,
+            unexpected_keys,
+            error_msgs,
+        )
