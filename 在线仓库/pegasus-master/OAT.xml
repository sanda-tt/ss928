<configuration>
    <oatconfig>
        <licensefile></licensefile>
        <policylist>
            <policy name="projectPolicy" desc="">
                <policyitem type="license" name="EndUserLicenseAgreement" path=".*" desc="Intel code"/>
                <policyitem type="license" name="CC-BY-4.0" path=".*" rule="may" group="defaultGroup" desc="License for documents"/>
                <policyitem type="license" name="Apache-2.0" path="!.*LICENSE" rule="may" group="defaultGroup" desc="HiSilicon copyright"/>
                <policyitem type="license" name="GPL" path=".*" desc="linux kernel adapter codes"/>
                <policyitem type="copyright" name="HiSilicon (Shanghai) Technologies Co., Ltd." path=".*" rule="may" group="defaultGroup"
                            filefilter="copyrightPolicyFilter" desc="HiSilicon (Shanghai) copyright"/>
                <policyitem type="copyright" name="Beijing Xunwei Electronics Co., Ltd" path=".*" rule="may" group="defaultGroup"
                            filefilter="copyrightPolicyFilter" desc="Beijing Xunwei Electronics copyright"/>
                <policyitem type="copyright" name="RKH Corp." path=".*" rule="may" group="defaultGroup"
                            filefilter="copyrightPolicyFilter" desc="RKH copyright"/>
                <policyitem type="copyright" name="Nanjing Qinuo Information Technology Co., Ltd." path=".*" rule="may" group="defaultGroup"
                            filefilter="copyrightPolicyFilter" desc="Nanjing Qinuo Information Technology Co., Ltd."/>
                <policyitem type="copyright" name="Dongguan EmbedFire Electronic Technology Co., Ltd." path=".*" rule="may" group="defaultGroup"
                            filefilter="copyrightPolicyFilter" desc="EmbedFire Electronic copyright"/>
            </policy>
        </policylist>
        <filefilterlist>
            <filefilter name="defaultPolicyFilter" desc="Filters for compatibility, license header policies">
                <filteritem type="filename" name="README"/>
                <filteritem type="filename" name="COPYRIGHT"/>
                <filteritem type="filename" name="NOTICE"/>
                <filteritem type="filename" name="*.xml|*.dtsi" desc="xml dtsi files"/>
                <filteritem type="filename" name="*.yuv|*.bgr|*.symvers" desc="Resource file of Hisilicon self-developed platform"/>
                <filteritem type="filename" name="Makefile.*|*.mak|*.mk|Make.linux" desc="Project Configuration file"/>
                <filteritem type="filepath" name="os/OpenHarmony/patch/device/soc/hisilicon/ss928v100/sdk_linux/open_source/.*" desc="Soft link file"/>
                <filteritem type="filepath" name="os/OpenHarmony/patch/device/soc/hisilicon/ss928v100/sdk_linux/smp" desc="Soft link file"/>
                <filteritem type="filepath" name="os/OpenHarmony/middleware/common/include/ot_mw_type.h" desc="Project Configuration file"/>
                <filteritem type="filepath" name="platform/ss928v100_clang/smp/a55_linux/mpp/component/security_subsys/cipher/built-in/build.mak.mbedtls"
                 desc="Project Configuration file"/>
                <filteritem type="filepath" name="platform/ss928v100_gcc/smp/a55_linux/mpp/component/security_subsys/cipher/built-in/build.mak.mbedtls"
                 desc="Project Configuration file"/>
            </filefilter>
            <filefilter name="copyrightPolicyFilter" desc="Filters for copyright header policies" >
                <filteritem type="filename" name="README"/>
                <filteritem type="filename" name="*.dox|*.xml|*.xsd|*.pdf|*.dtsi"/>
                <filteritem type="filename" name="*.yuv|*.bgr|*.symvers" desc="Resource file of Hisilicon self-developed platform"/>
                <filteritem type="filename" name="Makefile.*|*.mak|*.mk|Make.linux" desc="Project Configuration file"/>
                <filteritem type="filepath" name="os/OpenHarmony/patch/device/soc/hisilicon/ss928v100/sdk_linux/open_source/.*" desc="Soft link file"/>
                <filteritem type="filepath" name="os/OpenHarmony/patch/device/soc/hisilicon/ss928v100/sdk_linux/smp" desc="Soft link file"/>
                <filteritem type="filepath" name="os/OpenHarmony/middleware/common/include/ot_mw_type.h" desc="Project Configuration file"/>
                <filteritem type="filepath" name="platform/ss928v100_clang/smp/a55_linux/mpp/component/security_subsys/cipher/built-in/build.mak.mbedtls"
                 desc="Project Configuration file"/>
                 <filteritem type="filepath" name="platform/ss928v100_gcc/smp/a55_linux/mpp/component/security_subsys/cipher/built-in/build.mak.mbedtls"
                 desc="Project Configuration file"/>
                <filefilter name="readmeFileNamePolicyFilter" desc="Filters for README file policies">
                </filefilter>
            </filefilter>
            <filefilter name="binaryFileTypePolicyFilter" desc="Filters for binary file policies" >
                <filteritem type="filename" name="LICENSE"/>
                <filteritem type="filename" name="*.a|*.so|*.bin|*.ko|*.so.1" desc="Shared libraries of Hisilicon self-developed platform"/>
                <filteritem type="filename" name="*.bmp|*.png|*.h265|*.gif|*.bits|*.heic|*.h264|*.yuv|*.om|*.vec|*.jpg|*.seq|*.pcm|*.dat"
                 desc="Resource file of Hisilicon self-developed platform"/>
                <filteritem type="filename" name="*.pdf|*.xlsm|*.xlsx" desc="Development Documentation"/>
                <filteritem type="filename" name="*.tar.gz|*.pyc|*.tgz|*.tar.gz.*|*.zip" desc="Software tools"/>
            </filefilter>
            <filefilter name="licenseFileNamePolicyFilter" desc="Filters for LICENSE file policies">
            </filefilter>
            <filefilter name="readmeFileNamePolicyFilter" desc="Filters for README file policies">
            </filefilter>
        </filefilterlist>
    </oatconfig>
</configuration>
