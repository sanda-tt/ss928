     (iter->second)->OnIpSuccessChanged(DHCP_OPT_SUCCESS, ifname, result);
+#ifdef OHOS_ARCH_LITE
+    SaveDefaultRouteAndDns(result, ifname);
+#endif
     return DHCP_OPT_SUCCESS;
 }
