---
 platform/ss928v100_gcc/open_source/linux/Makefile | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/platform/ss928v100_gcc/open_source/linux/Makefile b/platform/ss928v100_gcc/open_source/linux/Makefile
index 4952e5706..6261d63b6 100644
--- a/platform/ss928v100_gcc/open_source/linux/Makefile
+++ b/platform/ss928v100_gcc/open_source/linux/Makefile
@@ -5,6 +5,7 @@ CHIP ?= ss928v100
 
 KERNEL_ORIGIN_VER:=linux-6.6.86
 KERNEL_VER:=linux-6.6.y
+HiEulerPi_KERNEL_PATCH:=HiEulerPI_gcc_linux-6.6.y.patch
 
 LLVM ?= 0
 ARCH_TYPE ?= arm64
@@ -39,6 +40,8 @@ ifneq ($(BUILD_DIR)/$(KERNEL_VER), $(wildcard $(BUILD_DIR)/$(KERNEL_VER)))
 	@echo -e $(GREEN)"patching kernel..."  $(DONE)
 	pushd $(BUILD_DIR);mv $(KERNEL_ORIGIN_VER) $(KERNEL_VER);popd
 	pushd $(BUILD_DIR)/$(KERNEL_VER); patch -p1< ../$(KERNEL_ORIGIN_VER).patch;popd
+	@echo -e $(GREEN)"patching kernel for HiEulerPi ..."  $(DONE)
+	pushd $(BUILD_DIR)/$(KERNEL_VER); patch -p1< ../$(HiEulerPi_KERNEL_PATCH);popd
 endif
 	$(MAKE) -C $(BUILD_DIR)/$(KERNEL_VER) ARCH=$(ARCH_TYPE) $(COMPILE_OPTIONS) $(KERNEL_CFG)
 	$(MAKE) -C $(BUILD_DIR)/$(KERNEL_VER) ARCH=$(ARCH_TYPE) $(COMPILE_OPTIONS) uImage
-- 
