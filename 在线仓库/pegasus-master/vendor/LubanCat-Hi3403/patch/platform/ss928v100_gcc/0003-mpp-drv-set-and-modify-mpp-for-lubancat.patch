 smp/a55_linux/interdrv/sysconfig/pin_mux.c    | 25 +++++
 smp/a55_linux/mpp/out/ko/load_ss928v100_user  |  9 +-
 smp/a55_linux/mpp/sample/Makefile.param       |  8 +-
 .../mpp/sample/common/sample_comm_audio.c     |  2 +-
 smp/a55_linux/mpp/sample/vio/sample_vio.c     |  4 +-
 smp/a55_linux/mpp/sample/vo/sample_vo.c       | 97 +++++++++++++++++++
 6 files changed, 134 insertions(+), 11 deletions(-)

diff --git a/smp/a55_linux/interdrv/sysconfig/pin_mux.c b/smp/a55_linux/interdrv/sysconfig/pin_mux.c
index c621a29e0..eebc80660 100644
--- a/smp/a55_linux/interdrv/sysconfig/pin_mux.c
+++ b/smp/a55_linux/interdrv/sysconfig/pin_mux.c
@@ -739,6 +739,29 @@ static void uart_pin_mux(int uart_index)
 }
 
 #endif
+
+#define FAN_CTRL_PWM 0
+
+void lubancat_hi3403_pin_mux(void)
+{
+    void *iocfg2_base = sys_config_get_reg_iocfg2(); 
+
+    sys_writel(iocfg2_base + 0x0030, 0x1200); /* SYS_LED GPIO4_2 */
+    sys_writel(iocfg2_base + 0x005C, 0x1200); /* WIFI_PWR_EN GPIO0_1 */
+
+#if FAN_CTRL_PWM
+    sys_writel(iocfg2_base + 0x0100, 0x1205); /* FAN_CTRL PWM0_OUT14 */
+#else
+    sys_writel(iocfg2_base + 0x0100, 0x1201); /* FAN_CTRL GPIO10_1 */
+#endif
+
+    sys_writel(iocfg2_base + 0x0110, 0x1201); /* TP_INT GPIO10_5 */
+    sys_writel(iocfg2_base + 0x0104, 0x1201); /* TP_RST GPIO10_2 */
+    sys_writel(iocfg2_base + 0x0108, 0x1101); /* LCD_PWR_EN GPIO10_3 */
+    sys_writel(iocfg2_base + 0x010C, 0x1101); /* LCD_RST GPIO10_4 */
+    // sys_writel(iocfg2_base + 0x01EC, 0x1201); /* LCD_BL PWM0_OUT1 */
+}
+
 void pin_mux(void)
 {
     int vo_intf_type = sys_config_get_vo_intf_type();
@@ -775,4 +798,6 @@ void pin_mux(void)
     if (audio_en != 0) {
         amp_unmute_pin_mux();
     }
+
+    lubancat_hi3403_pin_mux();
 }
