diff --git a/open_source/buildroot/Makefile b/open_source/buildroot/Makefile
new file mode 100644
index 000000000..b52d89bd4
--- /dev/null
+++ b/open_source/buildroot/Makefile
@@ -0,0 +1,45 @@
+BUILDROOT_TOP_DIR := $(shell pwd)
+
+ARCH ?= arm64
+RUN_JOBS ?= $(shell expr $(shell nproc) - 1)
+
+OSDRV_DIR ?= ../../osdrv
+OSDRV_CROSS ?= aarch64-openeuler-linux-gnu
+CROSS_COMPILE=$(OSDRV_CROSS)-
+
+BUILDROOT_VER ?= buildroot-2024.02.10
+
+all:
+	@echo "CROSS=$(CROSS)"
+	@echo "BUILDROOT_CFG=$(BUILDROOT_CFG)"
+
+	test -d $(BUILDROOT_VER) || (\
+		rm $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER) -rf ;\
+		tar xzf $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER).tar.gz -C $(BUILDROOT_TOP_DIR) ;\
+	);
+
+	test -d $(BUILDROOT_TOP_DIR)/dl && (\
+		rm -rf $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)/dl ;\
+		ln -sf $(BUILDROOT_TOP_DIR)/dl $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)/dl ;\
+	);
+
+	cp $(BUILDROOT_TOP_DIR)/$(BUILDROOT_CFG) $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)/configs/
+
+	$(MAKE) ARCH=$(ARCH) CROSS_COMPILE=$(CROSS_COMPILE) $(BUILDROOT_CFG) -C $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)
+	$(MAKE) ARCH=$(ARCH) CROSS_COMPILE=$(CROSS_COMPILE) source -C $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)
+	$(MAKE) ARCH=$(ARCH) CROSS_COMPILE=$(CROSS_COMPILE) -j$(RUN_JOBS) -C $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)
+
+	fakeroot tar xf $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)/output/images/rootfs.tar -C $(OSDRV_DIR)/pub/$(PUB_ROOTFS)
+	ln -sf /lib/firmware $(OSDRV_DIR)/pub/$(PUB_ROOTFS)/usr/lib/firmware 
+
+menuconfig:
+	cp -v $(BUILDROOT_TOP_DIR)/$(BUILDROOT_CFG) $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)/configs/
+	$(MAKE) ARCH=$(ARCH) CROSS_COMPILE=$(CROSS_COMPILE) $(BUILDROOT_CFG) -C $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)
+	$(MAKE) menuconfig -C $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)
+	$(MAKE) savedefconfig -C $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)
+	cp -v $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)/configs/$(BUILDROOT_CFG) $(BUILDROOT_TOP_DIR)/$(BUILDROOT_CFG)
+
+clean:
+	$(MAKE) distclean -C $(BUILDROOT_TOP_DIR)/$(BUILDROOT_VER)
+
+distclean: clean
