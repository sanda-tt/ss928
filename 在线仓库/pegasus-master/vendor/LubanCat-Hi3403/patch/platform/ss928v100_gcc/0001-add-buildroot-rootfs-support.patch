diff --git a/open_source/buildroot/overlay/etc/init.d/S99user b/open_source/buildroot/overlay/etc/init.d/S99user
new file mode 100755
index 000000000..2972d3208
--- /dev/null
+++ b/open_source/buildroot/overlay/etc/init.d/S99user
@@ -0,0 +1,91 @@
+#!/bin/bash
+#
+# user function
+#
+
+COMPATIBLE=$(strings /proc/device-tree/compatible)
+
+if [[ $COMPATIBLE =~ "lubancat,hi3403" ]]; then
+    CHIPNAME="hi3403"
+else
+    echo "board name error, please check dts or images!!!!!!!"
+fi
+
+_insmod ()
+{
+    ko_dir="/usr/lib/modules/"
+    ko_path=""
+
+    local mod_name="$1"
+    shift # Shift the first argument to get the rest
+
+    ko_path=$(find "$ko_dir" -name "$mod_name" -print -quit)
+
+    if [ -n "$ko_path" ]; then
+        echo "insmod $ko_path $*"
+        insmod "$ko_path" "$@"
+    else
+        echo "Error: Module '$mod_name' not found in $ko_dir"
+    fi
+}
+
+network_init()
+{
+    ethaddr1=$(ifconfig -a | grep "eth.*HWaddr" | awk '{print $5}')
+
+    if [ -f /etc/ethaddr.txt ]; then
+        ethaddr2=$(cat /etc/ethaddr.txt)
+        if [ "$ethaddr1" == "$ethaddr2" ]; then
+            echo "eth HWaddr cfg ok"
+        else
+            ifconfig eth0 down
+            ifconfig eth0 hw ether "$ethaddr2"
+        fi
+    else
+        echo "$ethaddr1" > /etc/ethaddr.txt
+    fi
+    ifconfig eth0 up
+
+    if [ "$CHIPNAME" == "hi3403" ]; then
+        echo "Set WIFI_PWR_EN(GPIO0_1) Enable"
+        gpioset gpiochip0 1=1
+        sleep 3s
+    fi
+
+    if ifconfig -a | grep -q wlan0; then
+        ifconfig wlan0 up
+        # wpa_supplicant -D nl80211 -i wlan0 -c /etc/wpa_supplicant.conf -B -d
+    fi
+}
+
+install_modules()
+{
+    if [ "$TOUCHSCREEN" = "EBF410655" ]; then
+        _insmod goodix_ts.ko invert_x=1 invert_y=1
+    fi
+}
+
+
+start() {
+    echo "Start run S99user"
+    install_modules
+    network_init &
+}
+
+stop() {
+    echo "OK"
+}
+
+case "$1" in
+    start)
+        start
+        ;;
+    stop)
+        stop
+        ;;
+    *)
+        echo "Usage: $0 {start|stop}"
+        exit 1
+esac
+
+exit $?
