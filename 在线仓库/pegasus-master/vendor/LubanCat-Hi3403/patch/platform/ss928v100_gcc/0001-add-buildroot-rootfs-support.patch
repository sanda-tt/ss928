@@ -0,0 +1,19 @@
+#!/bin/bash -e
+
+TARGET_ROOTFS_DIR=$1
+ROOTFSIMAGE=$2
+
+echo Making rootfs!
+
+# Apparent size + maxium alignment(file_count * block_size) + maxium journal size
+IMAGE_SIZE_MB=$(( $(fakeroot du --apparent-size -sm ${TARGET_ROOTFS_DIR} | cut -f1) + \
+	$(fakeroot find ${TARGET_ROOTFS_DIR} | wc -l) * 4 / 1024 + 64 ))
+
+# Extra 10%
+IMAGE_SIZE_MB=$(( $IMAGE_SIZE_MB * 110 / 100 ))
+
+rm -rf ${ROOTFSIMAGE}
+
+fakeroot mkfs.ext4 -d ${TARGET_ROOTFS_DIR} ${ROOTFSIMAGE} ${IMAGE_SIZE_MB}M
+
+echo Rootfs Image: ${ROOTFSIMAGE} size: ${IMAGE_SIZE_MB}M
