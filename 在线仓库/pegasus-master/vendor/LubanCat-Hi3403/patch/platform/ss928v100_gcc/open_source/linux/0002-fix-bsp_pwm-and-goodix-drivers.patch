From d7d4ce04487c398f9aea4a2f4924a7a8c5f6f265 Mon Sep 17 00:00:00 2001
From: hejiawencc <hjw0415@outlook.com>
Date: Fri, 27 Mar 2026 14:54:06 +0800
Subject: [PATCH 2/3] fix bsp_pwm and goodix drivers

---
 drivers/input/touchscreen/goodix.c | 62 ++++++++++++++++++++++++++++++
 drivers/pwm/pwm-bsp.c              |  9 +++--
 drivers/pwm/sysfs.c                |  4 +-
 3 files changed, 69 insertions(+), 6 deletions(-)

diff --git a/drivers/input/touchscreen/goodix.c b/drivers/input/touchscreen/goodix.c
index b068ff8af..81497a294 100644
--- a/drivers/input/touchscreen/goodix.c
+++ b/drivers/input/touchscreen/goodix.c
@@ -25,6 +25,18 @@
 #include <asm/unaligned.h>
 #include "goodix.h"
 
+static bool invert_x = false;
+static bool invert_y = false;
+static bool swap_x_y = false;
+
+module_param(invert_x, bool, 0644);
+module_param(invert_y, bool, 0644);
+module_param(swap_x_y, bool, 0644);
+
+MODULE_PARM_DESC(invert_x, "Invert touchscreen X axis");
+MODULE_PARM_DESC(invert_y, "Invert touchscreen Y axis");
+MODULE_PARM_DESC(swap_x_y, "Swap touchscreen X and Y axes");
+
 #define GOODIX_GPIO_INT_NAME		"irq"
 #define GOODIX_GPIO_RST_NAME		"reset"
 
@@ -1131,6 +1143,7 @@ static int goodix_configure_dev(struct goodix_ts_data *ts)
 {
 	int error;
 	int i;
+	int axis = ABS_MT_POSITION_X;
 
 	ts->int_trigger_type = GOODIX_INT_TRIGGER;
 	ts->max_touch_num = GOODIX_MAX_CONTACTS;
@@ -1172,9 +1185,26 @@ static int goodix_configure_dev(struct goodix_ts_data *ts)
 	/* Read configuration and apply touchscreen parameters */
 	goodix_read_config(ts);
 
+	memset(&ts->prop, 0, sizeof(ts->prop));
+
 	/* Try overriding touchscreen parameters via device properties */
 	touchscreen_parse_properties(ts->input_dev, true, &ts->prop);
 
+	if (invert_x) {
+		ts->prop.invert_x = true;
+		dev_info(&ts->client->dev, "Inverting touchscreen X axis\n");
+	}
+	if (invert_y) {
+		ts->prop.invert_y = true;
+		dev_info(&ts->client->dev, "Inverting touchscreen Y axis\n");
+	}
+	if (swap_x_y) {
+		ts->prop.swap_x_y = true;
+
+		swap(ts->input_dev->absinfo[axis], ts->input_dev->absinfo[axis + 1]);
+		dev_info(&ts->client->dev, "Swapping touchscreen X-Y axes\n");
+	}
+
 	if (!ts->prop.max_x || !ts->prop.max_y || !ts->max_touch_num) {
 		if (!ts->reset_controller_at_probe &&
 		    ts->irq_pin_access_method != IRQ_PIN_ACCESS_NONE) {
@@ -1409,6 +1439,38 @@ static void goodix_ts_remove(struct i2c_client *client)
 
 	if (ts->load_cfg_from_disk)
 		wait_for_completion(&ts->firmware_loading_complete);
+
+	/* Free IRQ if it was requested */
+	if (ts->gpiod_int && ts->gpiod_rst) {
+		goodix_free_irq(ts);
+	}
+
+	/* Reset the device to its initial state (Optional) */
+	if (ts->gpiod_int && ts->gpiod_rst) {
+		gpiod_direction_output(ts->gpiod_int, 0);
+		gpiod_direction_output(ts->gpiod_rst, 0);
+		usleep_range(5000, 6000);
+	}
+
+	/* Unregister the input device */
+	input_unregister_device(ts->input_dev);
+
+	/* Free the input device */
+	input_free_device(ts->input_dev);
+
+	/* Free GPIO resources */
+	if (ts->gpiod_int) {
+		gpiod_put(ts->gpiod_int);
+		ts->gpiod_int = NULL;
+	}
+
+	if (ts->gpiod_rst) {
+		gpiod_put(ts->gpiod_rst);
+		ts->gpiod_rst = NULL;
+	}
+
+	/* Optional: Free any additional allocated memory for the device data */
+	kfree(ts);
 }
 
 static int goodix_suspend(struct device *dev)
diff --git a/drivers/pwm/pwm-bsp.c b/drivers/pwm/pwm-bsp.c
index b9ef608f9..54bf5071a 100644
--- a/drivers/pwm/pwm-bsp.c
+++ b/drivers/pwm/pwm-bsp.c
@@ -270,7 +270,7 @@ static void bsp_pwm_set_polarity(struct pwm_chip *chip,
 				PWM_POLARITY_MASK, (0x0 << PWM_POLARITY_SHIFT));
 }
 
-static void bsp_pwm_get_state(struct pwm_chip *chip, struct pwm_device *pwm,
+static int bsp_pwm_get_state(struct pwm_chip *chip, struct pwm_device *pwm,
 				struct pwm_state *state)
 {
 	struct bsp_pwm_chip *bsp_pwm_chip = to_bsp_pwm_chip(chip);
@@ -295,6 +295,8 @@ static void bsp_pwm_get_state(struct pwm_chip *chip, struct pwm_device *pwm,
 
 	value = readl(base + pwm_ctrl_addr(pwm->hwpwm));
 	state->enabled = (PWM_ENABLE_MASK & value);
+
+	return 0;
 }
 
 static int bsp_pwm_apply(struct pwm_chip *chip, struct pwm_device *pwm,
@@ -400,7 +402,6 @@ static int bsp_pwm_probe(struct platform_device *pdev)
 
 static int bsp_pwm_remove(struct platform_device *pdev)
 {
-	int ret = 0;
 	int chip_loop;
 	struct bsp_pwm_chip *pwm_chip;
 	struct bsp_pwm_chip *pwm_chip_tmp;
@@ -415,9 +416,9 @@ static int bsp_pwm_remove(struct platform_device *pdev)
 
 		clk_disable_unprepare(pwm_chip->clk);
 
-		ret |= pwmchip_remove(&pwm_chip->chip);
+		pwmchip_remove(&pwm_chip->chip);
 	}
-	return ret;
+	return 0;
 }
 
 static const struct of_device_id bsp_pwm_of_match[] = {
diff --git a/drivers/pwm/sysfs.c b/drivers/pwm/sysfs.c
index 77e36341f..a469492c1 100644
--- a/drivers/pwm/sysfs.c
+++ b/drivers/pwm/sysfs.c
@@ -137,7 +137,7 @@ static ssize_t duty_cycle1_store(struct device *child,
 	mutex_lock(&export->lock);
 	pwm_get_state(pwm, &state);
 	state.duty_cycle1 = val;
-	ret = pwm_apply_state(pwm, &state);
+	ret = pwm_apply_might_sleep(pwm, &state);
 	mutex_unlock(&export->lock);
 
 	return ret ? : size;
@@ -172,7 +172,7 @@ static ssize_t duty_cycle2_store(struct device *child,
 	mutex_lock(&export->lock);
 	pwm_get_state(pwm, &state);
 	state.duty_cycle2 = val;
-	ret = pwm_apply_state(pwm, &state);
+	ret = pwm_apply_might_sleep(pwm, &state);
 	mutex_unlock(&export->lock);
 
 	return ret ? : size;
-- 
