+bool AudioCapturerServer::HandleTimestamp(SurfaceBuffer *surfaceBuf, int32_t readLen)
+{
+    Timestamp timestamp;
+    Timestamp::Timebase base = {};
+    bool ret = capturer_->GetTimestamp(timestamp, base);
+    if (!ret) {
+        MEDIA_ERR_LOG("No readtime get.");
+        return false;
+    }
+
+    errno_t retCopy = memcpy_s((uint8_t *)surfaceBuf->GetVirAddr(), sizeof(Timestamp), &timestamp, sizeof(Timestamp));
+    if (retCopy != EOK) {
+        MEDIA_ERR_LOG("retCopy = %x", retCopy);
+        return false;
+    }
+
+    surfaceBuf->SetSize(sizeof(Timestamp) + readLen);
+    return true;
+}
