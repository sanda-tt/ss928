+            virtual void OnDeviceChange(const AudioDeviceInfo &deviceInfo) = 0;
+            virtual void OnReadDataFailed() = 0;
+        };
+        enum AudioCapturerClientCall {
+            ON_DEVICE_CHANGED,
+            ON_READ_DATA_FAILED,
+        };
